{
    "name": "interview-assistant",
    "version": "1.1.0",
    "description": "Electron-based Interview Practice & Transparent Assist tool",
    "main": "main.js",
    "scripts": {
        "start": "node scripts/start-electron.js",
        "test": "node --test",
        "generate-keys": "node scripts/generate-keys.js",
        "create-icon": "node scripts/create-icon.js",
        "build": "node scripts/build-protected.js",
        "build:win": "electron-builder --win --config electron-builder.yml",
        "build:win:dir": "electron-builder --win --dir --config electron-builder.yml",
        "package": "npm run build && cd build-temp && npm run build:win",
        "package:quick": "electron-builder --win --config electron-builder.yml",
        "lint": "eslint . --ext .js,.ts",
        "lint:fix": "eslint . --ext .js,.ts --fix"
    },
    "author": "Interview Assistant",
    "license": "UNLICENSED",
    "private": true,
    "devDependencies": {
        "@eslint/js": "^9.39.0",
        "@typescript-eslint/eslint-plugin": "^8.46.2",
        "@typescript-eslint/parser": "^8.46.2",
        "cross-env": "^10.1.0",
        "electron": "^39.1.0",
        "electron-builder": "^24.13.3",
        "electron-packager": "^17.1.2",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "globals": "^16.4.0",
        "javascript-obfuscator": "^4.1.1",
        "png-to-ico": "^2.1.8",
        "sharp": "^0.33.5",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "axios": "^1.7.7",
        "dotenv": "^16.4.5",
        "ffmpeg-static": "^5.2.0",
        "fluent-ffmpeg": "^2.1.3",
        "form-data": "^4.0.5",
        "gpt-3-encoder": "^1.1.4",
        "mammoth": "^1.11.0",
        "openai": "^4.82.0",
        "pdf-parse": "^2.4.5",
        "tesseract.js": "^6.0.0",
        "uuid": "^11.0.5"
    },
    "build": {
        "appId": "com.interview-assistant.app",
        "productName": "Interview Assistant",
        "directories": {
            "output": "dist",
            "buildResources": "assets"
        },
        "files": [
            "**/*",
            "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
            "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
            "!scripts/generate-keys.js",
            "!scripts/build-protected.js",
            "!scripts/create-icon.js",
            "!build-assets/",
            "!build-temp/",
            "!unitTest/",
            "!tests/",
            "!docs/",
            "!**/*.md",
            "!.env*",
            "!.git*"
        ],
        "extraResources": [
            {
                "from": "node_modules/ffmpeg-static/",
                "to": "ffmpeg-static",
                "filter": ["**/*"]
            }
        ],
        "asar": true,
        "asarUnpack": [
            "node_modules/ffmpeg-static/**/*"
        ],
        "win": {
            "target": ["nsis"],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "packageManager": "npm@11.4.2"
}

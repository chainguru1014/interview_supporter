# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Web version (web/server.js) only ---
# Shared password that protects the hosted app. REQUIRED for public hosting,
# otherwise anyone with the URL can spend your API credits.
ACCESS_PASSWORD=pick-a-strong-password

# Port the web server listens on (optional; defaults to 3002 if unset)
PORT=3002
